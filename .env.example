# ── LLM Provider Keys (set at least one) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── NCBI / PubMed ─────────────────────────────────────────────────────────────
# Register free at: https://www.ncbi.nlm.nih.gov/account/
# Raises rate limit from 3 req/s → 10 req/s
NCBI_API_KEY=

# ── Agent defaults (optional overrides) ───────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | groq
LLM_MODEL=gpt-4o             # e.g. claude-opus-4-5, llama-3.3-70b-versatile
DEFAULT_MAX_RESULTS=20
EXPORT_DIR=./results
